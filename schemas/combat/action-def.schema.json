{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spaceface.game/schemas/combat/action-def.schema.json",
  "title": "SpaceFace ActionDef",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "tags", "phases", "cancelWindows", "cooldownTicks", "costs", "target", "requiresCapabilities", "effects", "cues"],
  "properties": {
    "id": { "type": "string", "pattern": "^action_[a-z0-9_]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "phases": {
      "type": "object", "additionalProperties": false,
      "required": ["startupTicks", "activeTicks", "recoveryTicks"],
      "properties": {
        "startupTicks": { "type": "integer", "minimum": 0 },
        "activeTicks": { "type": "integer", "minimum": 0 },
        "recoveryTicks": { "type": "integer", "minimum": 0 }
      }
    },
    "cancelWindows": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["phase", "fromTick", "toTick", "intoTags"],
        "properties": {
          "phase": { "enum": ["startup", "active", "recovery"] },
          "fromTick": { "type": "integer", "minimum": 0 },
          "toTick": { "type": "integer", "minimum": 1 },
          "intoTags": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "cooldownTicks": { "type": "integer", "minimum": 0 },
    "costs": {
      "type": "object", "additionalProperties": false,
      "required": ["capacitor", "heat"],
      "properties": {
        "capacitor": { "type": "number", "minimum": 0 },
        "heat": { "type": "number", "minimum": 0 }
      }
    },
    "target": {
      "type": "object",
      "required": ["kind", "required"],
      "properties": {
        "kind": { "enum": ["none", "entity", "attachment", "point"] },
        "required": { "type": "boolean" },
        "maxRange": { "type": "number", "minimum": 0 },
        "hostile": { "type": "boolean" },
        "ownedByActor": { "type": "boolean" },
        "sourceSocketTag": { "type": "string" },
        "targetSocketTag": { "type": "string" }
      },
      "additionalProperties": false
    },
    "requiresCapabilities": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "movement": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object", "additionalProperties": false,
          "required": ["at", "kind", "magnitude"],
          "properties": {
            "at": { "enum": ["startupStart", "activeStart", "activeEachTick", "recoveryStart"] },
            "kind": { "enum": ["forwardImpulse", "attachmentTangentImpulse"] },
            "magnitude": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "type"],
        "properties": {
          "at": { "enum": ["startupStart", "activeStart", "activeEachTick", "recoveryStart"] },
          "type": { "enum": ["createAttachment", "reelAttachment", "cutAttachment", "damage"] },
          "attachmentDefId": { "type": "string", "pattern": "^attachment_" },
          "restLengthDelta": { "type": "number" },
          "minRestLength": { "type": "number", "minimum": 0 },
          "reason": { "type": "string" },
          "packet": { "$ref": "damage-packet.schema.json" }
        },
        "additionalProperties": false
      }
    },
    "cues": {
      "type": "object", "additionalProperties": false,
      "required": ["start", "active", "end", "cancel", "reject"],
      "properties": {
        "start": { "type": "string", "minLength": 1 },
        "active": { "type": "string", "minLength": 1 },
        "end": { "type": "string", "minLength": 1 },
        "cancel": { "type": "string", "minLength": 1 },
        "reject": { "type": "string", "minLength": 1 }
      }
    }
  }
}
