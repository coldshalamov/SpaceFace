{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spaceface.game/schemas/combat/attachment-def.schema.json",
  "title": "SpaceFace AttachmentDef",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "sourceSocketTags", "targetSocketTags", "ownership", "break", "limits", "cues"],
  "properties": {
    "id": { "type": "string", "pattern": "^attachment_[a-z0-9_]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "sourceSocketTags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "targetSocketTags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "ownership": {
      "type": "object", "additionalProperties": false,
      "required": ["policy", "transferable"],
      "properties": {
        "policy": { "enum": ["initiator", "target", "neutral"] },
        "transferable": { "type": "boolean" }
      }
    },
    "break": {
      "type": "object", "additionalProperties": false,
      "required": ["maxTension", "maxImpulse", "graceTicks"],
      "properties": {
        "maxTension": { "type": "number", "minimum": 0 },
        "maxImpulse": { "type": "number", "minimum": 0 },
        "graceTicks": { "type": "integer", "minimum": 0 }
      }
    },
    "limits": {
      "type": "object", "additionalProperties": false,
      "required": ["maxPerOwner"],
      "properties": { "maxPerOwner": { "type": "integer", "minimum": 1 } }
    },
    "cues": {
      "type": "object", "additionalProperties": false,
      "required": ["created", "broken"],
      "properties": {
        "created": { "type": "string", "minLength": 1 },
        "broken": { "type": "string", "minLength": 1 }
      }
    }
  }
}
