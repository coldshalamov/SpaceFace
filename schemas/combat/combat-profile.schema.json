{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spaceface.game/schemas/combat/combat-profile.schema.json",
  "title": "SpaceFace CombatProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "entityTypes", "heat", "immunityTags", "subsystemIds", "sockets", "capabilities"],
  "properties": {
    "id": { "type": "string", "pattern": "^combat_profile_" },
    "version": { "type": "integer", "minimum": 1 },
    "entityTypes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "heat": {
      "type": "object", "additionalProperties": false,
      "required": ["max", "dissipationPerTick"],
      "properties": {
        "max": { "type": "number", "minimum": 0 },
        "dissipationPerTick": { "type": "number", "minimum": 0 }
      }
    },
    "immunityTags": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "subsystemIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^subsystem_" } },
    "sockets": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "tags", "localPos", "maxAttachments"],
        "properties": {
          "id": { "type": "string" },
          "tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "localPos": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
          "maxAttachments": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "capabilities": { "type": "object", "additionalProperties": { "type": "boolean" } }
  }
}
